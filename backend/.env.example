# Copy to .env and fill in values. The backend loads this automatically.
# .env is git-ignored; this file (.env.example) is the committed template.

# --- Server ---
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

# Comma-separated origins allowed to call the API. The Chrome extension's
# origin looks like chrome-extension://<extension-id>. During dev you can
# use "*" but tighten this before distributing the extension.
CORS_ORIGINS=*

# --- Database ---
# docker-compose spins up a pgvector-enabled Postgres on 5433 by default.
DATABASE_URL=postgresql+psycopg://factorcap:factorcap@localhost:5433/factorcap

# --- External APIs ---
# https://developers.google.com/fact-check/tools/api
# Enable the "Fact Check Tools API" in your GCP project; no billing required.
GOOGLE_FACTCHECK_API_KEY=

# --- Models ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
NLI_MODEL=MoritzLaurer/DeBERTa-v3-large-mnli-fever-anli-ling-wanli
CLAIM_EXTRACTION_MODEL=

# --- Retrieval ---
RETRIEVAL_TOP_K=10
RETRIEVAL_MIN_SIMILARITY=0.5

# --- Verdict thresholds ---
VERDICT_TRUE_THRESHOLD=0.3
VERDICT_FALSE_THRESHOLD=-0.3

# --- Cache ---
VERDICT_CACHE_TTL_SECONDS=3600
